{
  "entities": {
    "WorkLog": {
      "title": "WorkLog",
      "description": "일일 인력 배치 및 수수료 기록",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "문서 ID" },
        "userId": { "type": "string", "description": "소유자 UID" },
        "date": { "type": "string", "format": "date", "description": "작업 날짜 (YYYY-MM-DD)" },
        "workType": { "type": "string", "description": "현장명/업무 종류" },
        "unitPrice": { "type": "number", "description": "단가" },
        "workerCount": { "type": "number", "description": "인원수" },
        "totalAmount": { "type": "number", "description": "총액" },
        "commissionRate": { "type": "number", "description": "수수료율 (%)" },
        "commission": { "type": "number", "description": "수수료 금액" },
        "workerNames": { "type": "string", "description": "투입 인원 명단" },
        "notes": { "type": "string", "description": "비고/메모" },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성 일시" }
      },
      "required": ["userId", "date", "workType", "unitPrice", "workerCount", "totalAmount", "commissionRate", "commission", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "사용자 프로필 정보",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/workLogs/{logId}": {
      "schema": "WorkLog",
      "description": "업무 일지 컬렉션"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "사용자 정보 컬렉션"
    }
  }
}
