{
  "entities": {
    "WorkLog": {
      "title": "WorkLog",
      "description": "업무일지 기록",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "문서 ID" },
        "date": { "type": "string", "format": "date", "description": "날짜 (YYYY-MM-DD)" },
        "title": { "type": "string", "description": "제목" },
        "content": { "type": "string", "description": "내용" },
        "author": { "type": "string", "description": "작성자 이름" },
        "authorEmail": { "type": "string", "format": "email", "description": "작성자 이메일" },
        "createdAt": { "type": "string", "format": "date-time", "description": "생성 일시" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "수정 일시" }
      },
      "required": ["date", "title", "content", "authorEmail"]
    },
    "User": {
      "title": "User",
      "description": "사용자 프로필",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "사용자 UID" },
        "email": { "type": "string", "format": "email", "description": "이메일" },
        "displayName": { "type": "string", "description": "이름" },
        "photoURL": { "type": "string", "description": "프로필 사진 URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "권한" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/worklogs": {
      "schema": "WorkLog",
      "description": "업무일지 컬렉션"
    },
    "/users": {
      "schema": "User",
      "description": "사용자 컬렉션"
    }
  }
}
